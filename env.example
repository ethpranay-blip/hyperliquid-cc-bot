# === Portal Credentials ===
PORTAL_USER=your@email.com
PORTAL_PASSWORD=yourpassword

# === Hyperliquid ===
# Main wallet address (holds your funds)
HL_WALLET_ADDRESS=0x<your_main_wallet>
# ⚠️  API sub-wallet private key — NOT your main wallet key!
# Generate at: app.hyperliquid.xyz → API → Create API Wallet
HL_PRIVATE_KEY=0x<api_sub_wallet_private_key>

# === Trading Config ===
HL_LEVERAGE=10
HL_MARGIN_USD=100

# Margin mode for every order the bot opens. The bot calls update_leverage
# before each open with this value, so the choice persists across automated
# trades (HL UI changes get overridden). One of: isolated | cross
#   isolated — each trade has its own margin pool, blowups capped per-trade
#   cross    — all positions share collateral, more capital efficient,
#              one bad trade can drag others into liquidation
# Default: isolated (safer for unattended automation).
HL_MARGIN_MODE=isolated

# Order in which to search HIP-3 dexes when resolving an asset.
# Many assets are listed on multiple dexes (e.g. SILVER on xyz, cash, flx);
# the FIRST dex in this list that lists a coin wins. The default perp dex
# ("") is always probed first; this var only controls HIP-3 ordering.
# Comma-separated, no spaces. Default: xyz,cash,flx
HL_DEX_PRIORITY=xyz,cash,flx

# === Caller Whitelist ===
# Comma-separated userTags to copy. Defaults to voberoi,pranayyyy,corgil_
ALLOWED_CALLERS=voberoi,pranayyyy,corgil_

# === Safety ===
# Start with true! Simulates trades without placing real orders
DRY_RUN=true

# === Reconciliation ===
# How often (in seconds) to compare bot DB state against actual HL positions
# and clean up DB-only entries. After a manual close on the HL UI, the bot
# detects the change within this many seconds. Default: 60 (1 min).
# Lower = faster awareness; minimum recommended 30s (HL API rate limits).
RECONCILE_INTERVAL_SECONDS=60

# === Real-time HL state (Phase 2) ===
# When the HL userEvents WebSocket pushes a change (fill, manual close,
# manual SL move, liquidation), the bot debounces for this many seconds
# then triggers a reconcile. A burst of fills for one order coalesces
# into one reconcile. Lower = faster awareness; minimum recommended 1s
# to avoid reconcile storms during many partial fills. Default: 2.0
HL_CHANGE_DEBOUNCE_SECONDS=2.0

# === Stale-trade override ===
# Comma-separated trade IDs that should bypass the STALE check. Use this
# to take a legitimate but old call that was missed during downtime.
# Example: FORCE_ENTER_TIDS=665,666 takes ETH #665 and BTC #666 even
# though they're hours old. The bot will still respect BLOCKED (coin
# already live) and the margin pre-check.
FORCE_ENTER_TIDS=

# === Logging ===
LOG_LEVEL=INFO

# === Notifications (optional) ===
# Discord webhook: https://discord.com/api/webhooks/...
# Telegram bot: https://api.telegram.org/bot<token>/sendMessage
NOTIFY_WEBHOOK_URL=

# === Railway Deployment ===
# When deploying to Railway.app, create a volume in the Railway dashboard
# and set this environment variable to the mount path (typically /data).
# The bot will automatically use ${RAILWAY_VOLUME_MOUNT_PATH}/corgi.db
# for the database, ensuring data persists across deployments.
#
# Railway setup steps:
#   1. Create a new project from this GitHub repo
#   2. Add a Volume in the Railway dashboard (e.g., name it "corgi-data")
#   3. Set the mount path to /data
#   4. Set this environment variable: RAILWAY_VOLUME_MOUNT_PATH=/data
#   5. Set CORGI_DB_PATH=${RAILWAY_VOLUME_MOUNT_PATH}/corgi.db
#
# Without a volume, the database will reset on every deployment!
RAILWAY_VOLUME_MOUNT_PATH=/data
CORGI_DB_PATH=${RAILWAY_VOLUME_MOUNT_PATH}/corgi.db
